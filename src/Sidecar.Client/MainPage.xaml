<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:viewModels="clr-namespace:Sidecar.Client.ViewModels"
             xmlns:converters="clr-namespace:Sidecar.Client.Converters"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:controls="clr-namespace:Sidecar.Client.Controls"
             x:Class="Sidecar.Client.MainPage"
             ios:Page.UseSafeArea="False"
             NavigationPage.HasNavigationBar="False"
             x:DataType="viewModels:MainPageViewModel"
             BackgroundColor="Black">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:MuteIconConverter x:Key="MuteIconConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid BackgroundColor="Black" IgnoreSafeArea="True">
        <!-- iOS PiP用レイヤー (非表示) -->
        <controls:NativeVideoView x:Name="NativeViewer" 
                                  IsVisible="False" 
                                  IsPiPActive="{Binding IsPiPActive}" />

        <!-- 映像レイヤー -->
        <skia:SKCanvasView x:Name="CanvasView"
                           PaintSurface="OnCanvasViewPaintSurface"
                           IgnorePixelScaling="True"
                           BackgroundColor="Black" />

        <!-- 接続前UIレイヤー -->
        <ScrollView IsVisible="{Binding IsConnected, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="Black">
            <VerticalStackLayout Spacing="24" HorizontalOptions="Center" Padding="20,60,20,40" MaximumWidthRequest="400">
                <Label Text="Sidecar" 
                       FontSize="48" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center"
                       FontFamily="OpenSansSemibold"/>
                
                <Label Text="Remote Display Client" 
                       FontSize="16" 
                       TextColor="#808080" 
                       HorizontalTextAlignment="Center" 
                       Margin="0,-12,0,16"
                       CharacterSpacing="1"/>

                <!-- ホストアドレスとポート入力 -->
                <Grid ColumnDefinitions="2*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16" 
                            Stroke="Transparent" 
                            BackgroundColor="#252525" 
                            Padding="16,8">
                        <Entry Placeholder="ホストIP"
                               Text="{Binding HostAddress}"
                               IsEnabled="{Binding IsConnected, Converter={StaticResource InvertedBoolConverter}}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                               Keyboard="Url" />
                    </Border>

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16" 
                            Stroke="Transparent" 
                            BackgroundColor="#252525" 
                            Padding="16,8">
                        <Entry Placeholder="ポート"
                               Text="{Binding Port}"
                               IsEnabled="{Binding IsConnected, Converter={StaticResource InvertedBoolConverter}}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                               Keyboard="Numeric" />
                    </Border>
                </Grid>

                <!-- カラーモード選択 -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="カラーモード"
                           TextColor="White"
                           FontSize="12"/>
                    <Border StrokeShape="RoundRectangle 8" 
                            Stroke="Transparent" 
                            BackgroundColor="#252525" 
                            Padding="8,0">
                        <Picker ItemsSource="{Binding ColorModeOptions}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedItem="{Binding SelectedColorModeOption}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                Title="モードを選択"
                                TitleColor="#666666"
                                HorizontalOptions="Fill"/>
                    </Border>
                </VerticalStackLayout>
                
                <!-- Sliders -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding Saturation, StringFormat='Saturation: {0:F2}'}" TextColor="White" FontSize="12"/>
                    <Slider Value="{Binding Saturation}" Minimum="0" Maximum="3" />
                    
                    <Label Text="{Binding Contrast, StringFormat='Contrast: {0:F2}'}" TextColor="White" FontSize="12"/>
                    <Slider Value="{Binding Contrast}" Minimum="0" Maximum="3" />
                    
                    <Label Text="{Binding Brightness, StringFormat='Brightness: {0:F2}'}" TextColor="White" FontSize="12"/>
                    <Slider Value="{Binding Brightness}" Minimum="-1" Maximum="1" />
                    
                    <Button Text="Reset Sliders" 
                            Command="{Binding ResetSlidersCommand}"
                            HeightRequest="30"
                            Padding="0"
                            FontSize="10"
                            BackgroundColor="#444444" 
                            TextColor="White" />
                </VerticalStackLayout>

                <Button Text="Connect" 
                        Command="{Binding ConnectCommand}" 
                        BackgroundColor="#007AFF" 
                        TextColor="White" 
                        CornerRadius="24" 
                        HeightRequest="56" 
                        FontAttributes="Bold"
                        FontSize="16"
                        IsEnabled="{Binding IsNotConnecting}">
                    <Button.Shadow>
                        <Shadow Brush="#007AFF" Offset="0,4" Radius="10" Opacity="0.3"/>
                    </Button.Shadow>
                </Button>
                
                <Label Text="{Binding StatusMessage}" 
                       TextColor="#FF453A" 
                       HorizontalTextAlignment="Center"
                       FontSize="14"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- 接続中オーバーレイUI (タップで表示切り替え) -->
        <Grid IsVisible="{Binding IsConnected}" 
              InputTransparent="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </Grid.GestureRecognizers>
             
            <!-- コントロールコンテナ -->
            <Grid x:Name="ControlsOverlay" 
                  Opacity="0" 
                  InputTransparent="True" 
                  RowDefinitions="Auto,*,Auto">
                
                <!-- ヘッダー -->
                <Border Grid.Row="0" 
                        BackgroundColor="#CC1C1C1E" 
                        Padding="24,16" 
                        StrokeThickness="0"
                        VerticalOptions="Start">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <!-- 横画面ボタン (モバイルのみ) -->
                        <Button Grid.Column="0"
                                Text="⤢"
                                Command="{Binding ToggleLandscapeCommand}"
                                BackgroundColor="{Binding IsLandscapeLocked, Converter={StaticResource BoolToColorConverter}}"
                                TextColor="White"
                                FontSize="20"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="8"
                                Padding="0"
                                IsVisible="{Binding IsMobilePlatform}"/>
                        
                        <Label Grid.Column="1"
                               Text="{Binding StatusMessage}" 
                               TextColor="White" 
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>

                        <!-- PiPボタン (iOSのみ) -->
                        <Button Grid.Column="2"
                                Text="PiP"
                                Command="{Binding TogglePiPCommand}"
                                BackgroundColor="#333333"
                                TextColor="White"
                                FontSize="12"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="8"
                                Padding="0"
                                Margin="0,0,8,0"
                                IsVisible="{Binding IsMobilePlatform}"/>

                        <HorizontalStackLayout Grid.Column="3" Spacing="8">
                            <BoxView Color="#32D74B" WidthRequest="8" HeightRequest="8" CornerRadius="4" VerticalOptions="Center"/>
                            <Label Text="Live" TextColor="#32D74B" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- フッター -->
                <Border Grid.Row="2" 
                        BackgroundColor="#CC1C1C1E" 
                        Padding="16,20" 
                        StrokeThickness="0"
                        VerticalOptions="End">
                    <VerticalStackLayout Spacing="16">
                        <!-- オーディオコントロール -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MaximumWidthRequest="320" HorizontalOptions="Center">
                            <Button Grid.Column="0"
                                    Text="{Binding IsMuted, Converter={StaticResource MuteIconConverter}}"
                                    Command="{Binding ToggleMuteCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="20"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"/>
                            
                            <Slider Grid.Column="1"
                                    Value="{Binding Volume}"
                                    Minimum="0"
                                    Maximum="1"
                                    MinimumTrackColor="#007AFF"
                                    MaximumTrackColor="#444444"
                                    ThumbColor="White"
                                    VerticalOptions="Center"/>
                            
                            <Label Grid.Column="2" 
                                   Text="{Binding Volume, StringFormat='{0:P0}'}" 
                                   TextColor="#808080" 
                                   VerticalOptions="Center" 
                                   FontSize="11" 
                                   WidthRequest="35"/>
                        </Grid>

                        <Button Text="Disconnect" 
                                Command="{Binding DisconnectCommand}" 
                                BackgroundColor="#FF453A" 
                                TextColor="White" 
                                CornerRadius="20"
                                HeightRequest="40"
                                WidthRequest="120"
                                HorizontalOptions="Center"
                                FontSize="13"
                                FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
